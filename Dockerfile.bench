# Lightweight benchmarking image — no PyTorch, no Unsloth
# Size target: ~3GB
# Use this for PinchBench runs with Ollama + OpenClaw
FROM nvidia/cuda:12.4.1-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PATH="/root/.local/bin:/root/.openclaw/bin:/usr/local/bin:${PATH}"
ENV OLLAMA_HOST="0.0.0.0:11434"
ENV PBM_WORKSPACE="/workspace/synthbench"

# ── System packages ───────────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        curl \
        wget \
        git \
        vim \
        jq \
        openssl \
        ca-certificates \
        zstd \
    && ln -sf python3 /usr/bin/python \
    && rm -rf /var/lib/apt/lists/*

# ── Python packages (benchmark + data scripts only) ───────────────────────────
RUN pip3 install --no-cache-dir \
        pyyaml \
        anthropic \
        datasets \
        huggingface_hub \
        pandas \
        openpyxl \
        pdfplumber \
        PyPDF2 \
        tqdm \
        requests \
        jupyter \
        ipywidgets

# ── uv ────────────────────────────────────────────────────────────────────────
RUN curl -LsSf https://astral.sh/uv/install.sh | sh

# ── Ollama ────────────────────────────────────────────────────────────────────
RUN curl -fsSL https://ollama.com/install.sh | sh

# ── Node.js 22 + OpenClaw (real installer, not npm placeholder) ───────────────
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*
RUN curl -fsSL https://openclaw.ai/install.sh | bash

# ── Copy project ──────────────────────────────────────────────────────────────
COPY config.yaml             /root/config.yaml
COPY utils/                  /root/utils/
COPY scripts/                /root/scripts/
COPY generate.py             /root/generate.py
COPY inspect_data.py         /root/inspect_data.py
COPY llm_judge.py            /root/llm_judge.py
COPY repair.py               /root/repair.py
COPY topup.py                /root/topup.py
COPY openclaw_template.json  /root/openclaw_template.json

RUN chmod +x /root/scripts/*.sh

WORKDIR /root

CMD ["/bin/bash", "-c", "bash /root/scripts/startup.sh && tail -f /dev/null"]
